{
  "params": {
    "default_freq_hz": 433920000,
    "default_duration_ms": 1000,
    "secondary_freq_hz": 315000000
  },
  "on_run": [
    { "op": "log", "message": "medsec_passive_ism_watch - lab only - no TX" },
    { "op": "subghz_rx", "freq_hz": 433920000, "duration_ms": 1000 },
    { "op": "delay", "ms": 2000 },
    { "op": "subghz_rx", "freq_hz": 315000000, "duration_ms": 1000 },
    { "op": "log", "message": "medsec_passive_ism_watch sample complete" }
  ]
}
