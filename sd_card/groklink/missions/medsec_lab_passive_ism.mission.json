{
  "id": "medsec_lab_passive_ism",
  "name": "MedSec lab passive ISM sample",
  "version": 1,
  "autonomous": false,
  "schedule": {
    "type": "interval",
    "every_sec": 7200,
    "window_start": "00:00",
    "window_end": "23:59"
  },
  "safety": {
    "max_risk_class": "passive_rx",
    "require_confirm": false
  },
  "steps": [
    {
      "op": "log",
      "message": "medsec_lab_passive_ism - authorized lab only - no TX"
    },
    {
      "op": "subghz_rx",
      "freq_hz": 433920000,
      "duration_ms": 1000,
      "modulation": "auto"
    },
    {
      "op": "delay",
      "ms": 2000
    },
    {
      "op": "subghz_rx",
      "freq_hz": 315000000,
      "duration_ms": 1000,
      "modulation": "auto"
    },
    {
      "op": "decision",
      "if": { "metric": "subghz_pulse_count", "gte": 50 },
      "then": [{ "op": "log", "message": "elevated edges - log for analyst" }],
      "else": [{ "op": "log", "message": "baseline-like" }]
    },
    {
      "op": "log",
      "message": "medsec_lab_passive_ism complete"
    }
  ]
}
